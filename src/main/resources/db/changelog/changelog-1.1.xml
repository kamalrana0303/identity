<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="20251207-011-insert-user" author="kamalrana03">
        <insert tableName="users">
            <column name="username" value="jlong"/>
            <column name="password"
                    value="{bcrypt}$2a$10$w0eQPAJdEFW/ZmlwXyMZ2uyGq0B0FfzKy07TQCwO7G8pKHzlx4vIi"/>
            <column name="enabled" valueBoolean="true"/>
        </insert>
    </changeSet>
    <changeSet id="20251207-011-insert-authorities" author="kamalrana03">
        <insert tableName="authorities">
            <column name="username" value="jlong"/>
            <column name="authority" value="ROLE_USER"/>
        </insert>
    </changeSet>
    <changeSet id="20251207-011-insert-oauth2-registered-client" author="kamalrana03">
        <insert tableName="oauth2_registered_client">
            <column name="id" value="c1d2e3f4-5678-4a9b-8cde-1234567890ab"/>
            <column name="client_id" value="mangalsathi-client-oidc"/>
            <column name="client_id_issued_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="client_secret"
                    value="{bcrypt}$2a$10$w0eQPAJdEFW/ZmlwXyMZ2uyGq0B0FfzKy07TQCwO7G8pKHzlx4vIi"/>
            <column name="client_secret_expires_at" valueComputed="NULL"/>
            <column name="client_name" value="mangalsathi-client-oidc"/>
            <column name="client_authentication_methods" value="client_secret_basic"/>
            <column name="authorization_grant_types"
                    value='"authorization_code","refresh_token","client_credentials"'/>
            <column name="redirect_uris"
                    value='"http://127.0.0.1:8080/login/oauth2/code/mangalsathi-client-oidc","http://127.0.0.1:8080/authorized"'/>
            <column name="post_logout_redirect_uris"
                    value="http://127.0.0.1:8080/logged-out"/>
            <column name="scopes"
                    value='"user.read","user.write","openid","profile"'/>
            <column name="client_settings" value="{}"/>
            <column name="token_settings" value="{}"/>
        </insert>
    </changeSet>
</databaseChangeLog>